{
  "name": "sqlectron",
  "version": "1.39.0",
  "description": "A simple and lightweight SQL client with cross database and platform support",
  "author": {
    "name": "The Sqlectron Team",
    "email": "maxcnunes@gmail.com"
  },
  "main": "./out/browser/main.js",
  "license": "MIT",
  "homepage": "https://sqlectron.github.io",
  "bugs": "https://github.com/sqlectron/sqlectron-gui/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/sqlectron/sqlectron-gui"
  },
  "build": {
    "appId": "org.sqlectron.gui",
    "afterPack": "./build/afterPack.js",
    "mac": {
      "category": "public.app-category.developer-tools",
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "gatekeeperAssess": false,
      "hardenedRuntime": true,
      "notarize": true,
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "dmg": {
      "contents": [
        {
          "x": 438,
          "y": 275,
          "type": "link",
          "path": "/Applications"
        },
        {
          "x": 192,
          "y": 275,
          "type": "file"
        }
      ]
    },
    "linux": {
      "target": [
        "deb",
        "rpm",
        "freebsd",
        "pacman",
        "tar.xz",
        "tar.gz"
      ]
    },
    "win": {
      "azureSignOptions": {
        "publisherName": "Matthew Peveler",
        "endpoint": "https://eus.codesigning.azure.net/",
        "certificateProfileName": "Sqlectron",
        "codeSigningAccountName": "Sqlectron"
      },
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "ia32"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64",
            "ia32"
          ]
        }
      ]
    },
    "nsis": {
      "allowToChangeInstallationDirectory": true,
      "oneClick": false
    },
    "publish": {
      "provider": "github",
      "releaseType": "release"
    }
  },
  "scripts": {
    "prepare": "husky install && npx install-electron --no",
    "dev": "cross-env NODE_ENV=development concurrently --names \"webpack,electron\" --prefix name \"npm run dev:webpack\" \"npm run dev:electron\"",
    "dev:webpack": "webpack serve --color",
    "dev:electron": "npm run compile:browser && concurrently --kill-others --names \"build,run\" \"npm run compile:browser -- -w\" \"cross-env DEBUG=spawn-auto-restart node scripts/dev-auto-restart.js\"",
    "check-types": "tsc --noemit --project tsconfig.json",
    "eslint": "eslint .",
    "lint": "npm run eslint && npm run check-types",
    "lint:fix": "npm run lint -- --fix",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "test": "npm run test:browser && npm run test:renderer",
    "test:e2e": "vitest run --config vitest.e2e.config.mts",
    "test:e2e:dev": "cross-env DEV_MODE=true npm run test:e2e",
    "test:browser": "vitest run test/browser",
    "test:renderer": "vitest run test/renderer test/common",
    "clean": "rimraf dist",
    "clean:macos": "rimraf dist/Sqlectron-darwin-*",
    "clean:win": "rimraf dist/win* dist/Sqlectron-win*",
    "clean:linux": "rimraf dist/Sqlectron-linux-* dist/*.deb",
    "compile": "rimraf out && npm run compile:browser && npm run compile:renderer",
    "compile:browser": "tsc --project tsconfig.build.json",
    "compile:renderer": "cross-env NODE_ENV=production webpack --progress --stats-error-details",
    "build:macos": "npm run clean:macos && electron-builder --macos",
    "build:linux": "npm run clean:linux && electron-builder --linux",
    "build:win": "npm run clean:win && electron-builder --windows",
    "dist": "npm run compile && electron-builder",
    "storybook": "start-storybook -p 6006",
    "build-storybook": "build-storybook"
  },
  "dependencies": {
    "@babel/core": "^7.14.3",
    "@types/react-virtualized": "^9.21.16",
    "connection-string": "^4.3.4",
    "core-js": "^3.6.5",
    "csv-stringify": "^5.5.1",
    "electron-log": "^5.4.4",
    "env-paths": "^1.0.0",
    "joi": "^17.13.3",
    "lodash": "^4.17.21",
    "sqlectron-db-core": "^0.12.0",
    "uuid": "^8.3.2"
  },
  "devDependencies": {
    "@babel/cli": "^7.14.3",
    "@babel/plugin-proposal-class-properties": "^7.13.0",
    "@babel/preset-env": "^7.14.2",
    "@babel/preset-react": "^7.13.13",
    "@babel/preset-typescript": "^7.13.0",
    "@codemirror/autocomplete": "^6.20.3",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/search": "^6.7.1",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.1",
    "@eslint/js": "^9.39.4",
    "@radix-ui/react-dialog": "^1.1.16",
    "@reduxjs/toolkit": "^2.0.0",
    "@storybook/addon-actions": "^6.4.17",
    "@storybook/addon-essentials": "^6.4.17",
    "@storybook/addon-links": "^6.4.17",
    "@storybook/builder-webpack5": "^6.4.17",
    "@storybook/react": "^6.4.17",
    "@testing-library/dom": "^10.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jsdom": "^16.2.8",
    "@types/lodash": "^4.14.178",
    "@types/node": "^24.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@types/react-resizable": "^3.0.2",
    "@types/react-router": "^5.1.18",
    "@types/react-tabs": "^2.3.4",
    "@types/redux-logger": "^3.0.9",
    "@types/webpack-env": "^1.16.0",
    "@uiw/codemirror-theme-github": "^4.25.10",
    "@uiw/react-codemirror": "^4.25.10",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.2.5",
    "babel-loader": "^8.2.2",
    "class-variance-authority": "^0.7.1",
    "classnames": "^2.3.1",
    "clsx": "^2.1.1",
    "concurrently": "^2.2.0",
    "cross-env": "^7.0.2",
    "csp-html-webpack-plugin": "^5.1.0",
    "css-loader": "^5.2.5",
    "dom-helpers": "^5.1.4",
    "dotenv": "^10.0.0",
    "dotenv-webpack": "^7.0.2",
    "electron": "^42.0.0",
    "electron-builder": "26.15.3",
    "electron-devtools-installer": "^4.0.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "file-loader": "^6.0.0",
    "globals": "^17.6.0",
    "html-webpack-plugin": "^5.3.1",
    "husky": "^5.1.1",
    "jsdom": "^16.5.1",
    "json-loader": "^0.5.4",
    "lint-staged": "^10.5.4",
    "lucide-react": "^1.17.0",
    "mini-css-extract-plugin": "^1.6.0",
    "playwright-core": "^1.60.0",
    "postcss": "^8.3.0",
    "postcss-loader": "^5.3.0",
    "prettier": "^3.8.4",
    "prop-types": "^15.7.2",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-draggable": "^4.5.0",
    "react-redux": "^9.0.0",
    "react-resizable": "^3.0.4",
    "react-router": "^5.2.0",
    "react-router-dom": "^5.2.0",
    "react-select": "^4.3.0",
    "react-tabs": "^3.2.2",
    "react-virtualized": "^9.22.3",
    "redux-logger": "^3.0.6",
    "rimraf": "^3.0.2",
    "sass": "^1.49.0",
    "sass-loader": "^11.0.1",
    "spawn-auto-restart": "^3.1.1",
    "sql-formatter": "^4.0.2",
    "style-loader": "^1.2.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^3.4.19",
    "tailwindcss-animate": "^1.0.7",
    "ts-loader": "^8.0.17",
    "typescript": "^5.9.3",
    "typescript-eslint": "8.55.0",
    "url-loader": "^4.1.0",
    "vitest": "^3.2.6",
    "webpack": "^5.36.2",
    "webpack-cli": "^4.7.0",
    "webpack-dev-server": "^4.7.2"
  },
  "allowScripts": {
    "core-js@3.15.2": true,
    "core-js-pure@3.47.0": true,
    "electron-winstaller@5.4.0": true,
    "esbuild@0.25.12": true,
    "fsevents@2.3.3": true,
    "fsevents@1.2.13": true,
    "sqlite3@5.1.7": true,
    "ssh2@1.17.0": true
  }
}
